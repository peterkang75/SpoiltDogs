# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://...          # Supabase Postgres (pooler recommended)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only, DO NOT expose
SUPABASE_ANON_KEY=eyJ...               # used by VITE_SUPABASE_ANON_KEY too
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

ADMIN_PASSWORD=change-me-long-random
SESSION_SECRET=change-me-long-random

ANTHROPIC_API_KEY=sk-ant-...
FAL_API_KEY=...
OPENAI_API_KEY=sk-...                  # used by adminRoutes / routes
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...   # used by replit_integrations modules (chat/image/audio)
AI_INTEGRATIONS_OPENAI_BASE_URL=        # optional, leave blank for default

# ── Optional ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0                           # Railway sets this automatically
RESEND_API_KEY=re_...
CONTACT_RECIPIENT_EMAIL=you@example.com
WC_CONSUMER_KEY=ck_...
WC_CONSUMER_SECRET=cs_...
STORE_URL=https://your-wc-store.com

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for test mode
STRIPE_PUBLISHABLE_KEY=pk_live_...      # or pk_test_... for test mode
STRIPE_WEBHOOK_SECRET=whsec_...         # from Stripe Dashboard → Webhooks (endpoint: /api/stripe/webhook)
